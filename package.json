{
  "name": "@flutchai/flutch-sdk",
  "version": "0.5.0",
  "type": "module",
  "description": "Base infrastructure package for building graph microservices - core interfaces, types, utilities, and execution engine",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "default": "./dist/core/index.js"
    },
    "./callbacks": {
      "types": "./dist/callbacks/index.d.ts",
      "default": "./dist/callbacks/index.js"
    },
    "./graph": {
      "types": "./dist/graph/index.d.ts",
      "default": "./dist/graph/index.js"
    },
    "./engines": {
      "types": "./dist/engines/index.d.ts",
      "default": "./dist/engines/index.js"
    },
    "./agent-ui": {
      "types": "./dist/agent-ui/index.d.ts",
      "default": "./dist/agent-ui/index.js"
    },
    "./tools": {
      "types": "./dist/tools/index.d.ts",
      "default": "./dist/tools/index.js"
    },
    "./messages": {
      "types": "./dist/messages/index.d.ts",
      "default": "./dist/messages/index.js"
    },
    "./models": {
      "types": "./dist/models/index.d.ts",
      "default": "./dist/models/index.js"
    },
    "./retriever": {
      "types": "./dist/retriever/index.d.ts",
      "default": "./dist/retriever/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "default": "./dist/utils/index.js"
    },
    "./oauth": {
      "types": "./dist/oauth/index.d.ts",
      "default": "./dist/oauth/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/flutchai/node-sdk.git"
  },
  "keywords": [
    "flutch",
    "langgraph",
    "nestjs",
    "ai",
    "microservices",
    "graph",
    "sdk",
    "langchain",
    "typescript"
  ],
  "author": "Flutchai",
  "license": "MIT",
  "scripts": {
    "build": "tsup",
    "test": "jest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.4.0",
    "@langchain/aws": "^1.3.9",
    "@langchain/cohere": "^1.0.5",
    "@langchain/core": "^1.1.48",
    "@langchain/langgraph": "^1.3.7",
    "@langchain/langgraph-checkpoint-mongodb": "1.3.3",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.2",
    "@langchain/mistralai": "^1.1.0",
    "@langchain/openai": "^1.4.7",
    "axios": "^1.17.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "ioredis-mock": "^8.13.1",
    "mongodb": "^6.21.0",
    "rxjs": "^7.8.2",
    "zod": "^3.25.76",
    "zod-from-json-schema": "^0.5.2",
    "zod-to-json-schema": "^3.25.2"
  },
  "peerDependencies": {
    "@nestjs/axios": "^4.0.0",
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/config": "^3.0.0 || ^4.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "@nestjs/mongoose": "^10.0.0 || ^11.0.0",
    "@nestjs/platform-express": "^10.0.0 || ^11.0.0",
    "@nestjs/swagger": "^7.0.0 || ^11.0.0",
    "@nestjs/terminus": "^10.0.0 || ^11.0.0",
    "@willsoto/nestjs-prometheus": "^5.0.0 || ^6.0.0",
    "ioredis": "^5.3.0",
    "mongoose": "^8.0.0",
    "prom-client": "^14.0.0 || ^15.0.0",
    "reflect-metadata": "^0.2.0"
  },
  "peerDependenciesMeta": {
    "@langchain/langgraph-checkpoint-postgres": {
      "optional": true
    },
    "@nestjs/axios": {
      "optional": true
    },
    "@nestjs/mongoose": {
      "optional": true
    },
    "@nestjs/swagger": {
      "optional": true
    },
    "@nestjs/terminus": {
      "optional": true
    },
    "@willsoto/nestjs-prometheus": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "mongoose": {
      "optional": true
    },
    "prom-client": {
      "optional": true
    }
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.26",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.26",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/platform-express": "^11.1.26",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/terminus": "^11.1.1",
    "@types/express": "^5.0.6",
    "@types/ioredis-mock": "^8",
    "@types/jest": "^30.0.0",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^24.13.1",
    "@willsoto/nestjs-prometheus": "^6.1.0",
    "ioredis": "^5.11.1",
    "ioredis-mock": "^8.13.1",
    "jest": "^29.7.0",
    "json-schema": "^0.4.0",
    "mongoose": "^8.24.0",
    "prettier": "^3.8.4",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "ts-jest": "^29.4.11",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "packageManager": "yarn@4.16.0"
}
